{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
    "configurePresets": [
        {
            "name": "vs2022",
            "displayName": "Visual Studio 2022 (x64)",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/vs2022"
        },
        {
            "name": "debug",
            "displayName": "Debug (Ninja/Make)",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "release",
            "displayName": "Release (Ninja/Make)",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        }
    ],
    "buildPresets": [
        { "name": "vs2022-debug", "configurePreset": "vs2022", "configuration": "Debug" },
        { "name": "vs2022-release", "configurePreset": "vs2022", "configuration": "Release" },
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" }
    ],
    "testPresets": [
        { "name": "vs2022", "configurePreset": "vs2022", "configuration": "Release" },
        { "name": "debug", "configurePreset": "debug" },
        { "name": "release", "configurePreset": "release" }
    ]
}
